# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change-me-db-password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
FRONTEND_URL=http://localhost

# ── IntaSend (M-Pesa) ─────────────────────────────────────────────────────────
INTASEND_PUBLIC_KEY=your-intasend-public-key
INTASEND_PRIVATE_KEY=your-intasend-private-key
INTASEND_BASE_URL=https://sandbox.intasend.com

# ── Media Server ──────────────────────────────────────────────────────────────
MEDIA_SERVER_KEY=change-me-media-server-secret

# ── LiveKit (Commentary audio rooms) ─────────────────────────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret0000000000000000000000
LIVEKIT_URL=wss://livekit:7880
# Public URL sent to browser clients — set to wss://your-domain.com/livekit or the LiveKit cloud URL
LIVEKIT_PUBLIC_URL=
