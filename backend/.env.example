# ── Server ──────────────────────────────────────────────────────────────────
PORT=8000
APP_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://apex:password@postgres:5432/livestreamify?sslmode=disable

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_ADDR=redis:6379
REDIS_PASSWORD=redispassword

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI to add: http://localhost:3000/auth/callback  (dev)
#                                  https://yourdomain.com/auth/callback (prod)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── IntaSend (M-Pesa) ────────────────────────────────────────────────────────
INTASEND_PUBLIC_KEY=your-intasend-public-key
INTASEND_PRIVATE_KEY=your-intasend-private-key
INTASEND_BASE_URL=https://sandbox.intasend.com

# ── Media Server ─────────────────────────────────────────────────────────────
MEDIA_SERVER_URL=http://media-server:8888
MEDIA_SERVER_KEY=change-me-media-server-secret
RTMP_INGEST_URL=rtmp://localhost/live

# ── SMTP (email notifications) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=noreply@livestreamify.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@livestreamify.com
SMTP_FROM_NAME=Live Streamify
APP_URL=http://localhost:3000
